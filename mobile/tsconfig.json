{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/stores/AppContext": ["src/stores/AppContext"],
      "@/lib/geo/location": ["src/lib/geo/location"],
      "@/hooks/useInstallPrompt": ["src/hooks/useInstallPrompt"],
      "@/components/layout/SettingsModal": ["src/components/layout/SettingsModal"],
      "@/components/forecast/SkyChart": ["src/components/forecast/SkyChart"],
      "@/*": ["../web/src/*"]
    }
  },
  "include": ["src", "../web/src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
