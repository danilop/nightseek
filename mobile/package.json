{
  "name": "nightseek-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "NightSeek - Native iOS/macOS App (Capacitor)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
